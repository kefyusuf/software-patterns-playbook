{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": [
    "payment-strategy/**/*.ts",
    "order-domain-event/**/*.ts",
    "notification-adapter/**/*.ts",
    "order-repository-dto/**/*.ts",
    "order-specification/**/*.ts",
    "checkout-chain/**/*.ts",
    "order-processing-state/**/*.ts"
  ]
}
